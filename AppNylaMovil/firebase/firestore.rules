rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'sistemsvlu@gmail.com';
    }
    
    // User documents - only owner can read/write
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /profile/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /tasks/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /notes/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /calendar/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /routines/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /reminders/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Access logs - cualquier usuario autenticado puede escribir, solo admin puede leer
    match /access_logs/{logId} {
      allow create: if isAuthenticated();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
