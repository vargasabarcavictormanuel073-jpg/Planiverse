rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredTimestamps() {
      return request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
    }
    
    function hasUpdatedTimestamp() {
      return request.resource.data.keys().hasAll(['updatedAt']);
    }
    
    // User documents - only owner can read/write
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Profile subcollection - más flexible para permitir creación/actualización
      match /profile/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      // Tasks subcollection
      match /tasks/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredTimestamps();
        allow update: if isOwner(userId) && hasUpdatedTimestamp();
        allow delete: if isOwner(userId);
      }
      
      // Notes subcollection
      match /notes/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredTimestamps();
        allow update: if isOwner(userId) && hasUpdatedTimestamp();
        allow delete: if isOwner(userId);
      }
      
      // Calendar subcollection
      match /calendar/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredTimestamps();
        allow update: if isOwner(userId) && hasUpdatedTimestamp();
        allow delete: if isOwner(userId);
      }
      
      // Routines subcollection
      match /routines/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredTimestamps();
        allow update: if isOwner(userId) && hasUpdatedTimestamp();
        allow delete: if isOwner(userId);
      }
      
      // Reminders subcollection
      match /reminders/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredTimestamps();
        allow update: if isOwner(userId) && hasUpdatedTimestamp();
        allow delete: if isOwner(userId);
      }
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
